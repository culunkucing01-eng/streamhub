# === WAJIB DIISI ===

# Domain kamu (tanpa https://)
DOMAIN=streamhub.example.com

# Password database — gunakan password yang kuat
POSTGRES_PASSWORD=ganti_dengan_password_kuat

# JWT secret — minimal 32 karakter acak
# Generate dengan: openssl rand -hex 32
JWT_SECRET=ganti_dengan_secret_panjang_dan_acak

# === OPSIONAL ===

# Database
POSTGRES_DB=streamhub
POSTGRES_USER=streamhub

# SRS Media Server (jika pakai SRS terpisah)
SRS_API_URL=http://srs:1985
SRS_PLAYBACK_URL=http://srs:8080

# Google OAuth (opsional, untuk Login with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
